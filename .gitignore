node_modules/
dist/
out/
build/Release/
coverage/
*.tsbuildinfo
.turbo/

# Electron packaging output
apps/desktop/release/

# Python sidecar
sidecar/.venv/
__pycache__/
*.pyc
.pytest_cache/
sidecar/dist/
sidecar/build/

# Model weights and captures are never committed
models/
apps/desktop/src/renderer/public/models/
captures/
*.onnx
*.pt
*.pth
*.safetensors

# Editor and OS
.DS_Store
.idea/
.vscode/*
!.vscode/extensions.json
*.log

# Bundled relocatable Python (produced by bundle-python.mjs; large, per-platform)
apps/desktop/resources/python/*
!apps/desktop/resources/python/.gitkeep

# Bundled Depth Anything V2 ONNX (produced by bundle-python.mjs; large)
apps/desktop/resources/models/*
!apps/desktop/resources/models/.gitkeep
