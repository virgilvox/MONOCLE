{
  "extends": "@monoclejs/tsconfig/base.json",
  "compilerOptions": {
    "composite": true,
    "lib": ["ES2023"],
    "types": ["node", "electron-vite/node"],
    "moduleResolution": "Bundler",
    "noEmit": true,
    "outDir": "out"
  },
  "include": [
    "src/main/**/*.ts",
    "src/preload/**/*.ts",
    "src/shared/**/*.ts",
    "electron.vite.config.ts"
  ]
}
