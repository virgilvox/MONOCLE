{
  "name": "@monoclejs/desktop",
  "version": "0.1.0",
  "description": "MONOCLE desktop app: the Vue UI, Electron shell, and inference sidecar supervisor.",
  "private": true,
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "package": "electron-vite build && electron-builder",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json",
    "typecheck:web": "vue-tsc --noEmit -p tsconfig.web.json",
    "clean": "rimraf out dist release .turbo *.tsbuildinfo"
  },
  "dependencies": {
    "@monoclejs/core": "workspace:*",
    "@monoclejs/mesh-io": "workspace:*",
    "@monoclejs/protocol": "workspace:*"
  },
  "devDependencies": {
    "@monoclejs/tsconfig": "workspace:*",
    "@types/node": "^22.10.0",
    "@vitejs/plugin-vue": "^5.2.0",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "electron-vite": "^3.0.0",
    "pinia": "^3.0.0",
    "rimraf": "^6.0.1",
    "typescript": "^5.9.0",
    "vite": "^6.0.0",
    "vue": "^3.5.13",
    "vue-tsc": "^2.2.0"
  }
}
